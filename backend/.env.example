DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/consent_dashboard
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_BASE_URL=https://zentrust.atlassian.net/wiki
CONFLUENCE_SPACE_KEYS=CR

AHA_API_KEY=your_aha_api_key
AHA_BASE_URL=https://company.aha.io/api/v1
AHA_PRODUCT_KEY=CD

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://xxxx.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-pro
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

BACKGROUND_JOBS_ENABLED=true
SYNC_INTERVAL_MINUTES=15
CACHE_TTL=300
MAX_EMBEDDING_BATCH_SIZE=100

COSMOS_ENDPOINT=
COSMOS_KEY=<rotated-key-here>
COSMOS_DATABASE_NAME=<your-database-name>